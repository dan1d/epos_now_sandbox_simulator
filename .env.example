# Epos Now API credentials
# Get these from your Epos Now Backoffice by registering an API Device
EPOS_NOW_API_KEY=your_api_key_here
EPOS_NOW_API_SECRET=your_api_secret_here
EPOS_NOW_DEVICE_NAME=My Test Device

# Optional: override API URL (default: https://api.eposnowhq.com)
# EPOS_NOW_API_URL=https://api.eposnowhq.com

# Business type: restaurant, cafe_bakery, bar_nightclub, retail_general
BUSINESS_TYPE=restaurant

# Tax rate percentage
TAX_RATE=8.25

# Timezone (IANA format)
MERCHANT_TIMEZONE=America/Los_Angeles

# Logging level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO
